# Database (MySQL)
DB_URL=jdbc:mysql://localhost:3306/carshop_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# VNPAY
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=http://localhost:8080/api/thanh-toan/vnpay/return
VNPAY_FRONTEND_RETURN_URL=http://localhost:3000/payment/vnpay-result

# GHN
GHN_TOKEN=your_ghn_token
GHN_SHOP_ID=your_ghn_shop_id
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
