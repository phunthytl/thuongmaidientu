# ============================
# Copy this file to .env (same folder as docker-compose.yml) and fill in real values.
# docker-compose will auto-load .env
# ============================

# ---- Ports (optional override) ----
FRONTEND_PORT=80
BACKEND_PORT=8080
DB_PORT=3306

# ---- Database ----
DB_NAME=carshop_db
DB_USERNAME=carshop
DB_PASSWORD=CHANGE_ME_strong_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password
JPA_DDL_AUTO=update

# ---- JWT (REQUIRED — generate via PowerShell: [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))) ----
JWT_SECRET=CHANGE_ME_64_char_random_base64_string
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- GHN (Giao Hang Nhanh) ----
GHN_TOKEN=
GHN_SHOP_ID=
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2

# ---- VNPAY ----
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost/api/thanh-toan/vnpay/return
VNPAY_FRONTEND_RETURN_URL=http://localhost/thanh-toan/ket-qua
